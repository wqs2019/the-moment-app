    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.the.moments.app",
      "appleTeamId": "592UG636F5",
      "usesAppleSignIn": true
    },
    "android": {
      "edgeToEdgeEnabled": true,
      "package": "com.the.moments.app"
    },
    "extra": {
      "eas": {
        "projectId": ""
      }
    },
    "plugins": [
      "expo-font",
      "expo-apple-authentication"
    ]
  }
}
